# Copy the values you need into `.env.local`.
# Keep real secrets out of committed files.

APP_SECRET=replace-with-a-random-app-secret
JWT_PASSPHRASE=replace-with-a-random-jwt-passphrase

# Optional local overrides
# DATABASE_URL="mysql://app:app@127.0.0.1:3306/app?serverVersion=11.4.0-MariaDB&charset=utf8mb4"
# FIXTURE_ADMIN_PASSWORD=change-me

# PWA / Web Push
WEB_PUSH_VAPID_SUBJECT=https://komm.example.com
WEB_PUSH_VAPID_PUBLIC_KEY=replace-with-your-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=replace-with-your-vapid-private-key
